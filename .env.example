# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- Backend ---
# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed frontend origins (set in Railway env vars)
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=

# --- Frontend (set in Vercel environment variables) ---
# Your Railway backend URL — no trailing slash, no /api
# Example: VITE_API_URL=https://your-backend.up.railway.app
VITE_API_URL=
